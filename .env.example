GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional. Defaults to <current-origin>/api/auth/github
# GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github
# Optional. Defaults to "read:user user:email"
# GITHUB_AUTH_SCOPES=read:user user:email
# Optional. Defaults to 90.
# OSS_ORG_FOLLOWER_THRESHOLD=90
# Optional. Defaults to 2 pages of GitHub merged PR search results.
# OSS_GITHUB_SEARCH_PAGES=2
# Optional. Falls back to GITHUB_CLIENT_SECRET when omitted.
# SESSION_SECRET=
